#!/usr/bin/env bash
set -euo pipefail

BOOK_SRC="book-src"
BOOK_PREFACE="book-preface.md"

rm -rf "$BOOK_SRC"
mkdir -p "$BOOK_SRC"

copy_markdown_tree() {
  local dir="$1"

  if [ ! -d "$dir" ]; then
    return
  fi

  find "$dir" -type f -name '*.md' -print0 | while IFS= read -r -d '' file; do
    local dest="$file"

    mkdir -p "$BOOK_SRC/$(dirname "$dest")"
    cp "$file" "$BOOK_SRC/$dest"
  done
}

title_for() {
  local file="$1"
  local title

  title="$(sed -n 's/^# //p' "$file" | head -n 1)"
  if [ -n "$title" ]; then
    printf '%s\n' "$title"
  else
    basename "$file" .md
  fi
}

append_entry() {
  local file="$1"

  append_entry_from "$file" "$file"
}

append_entry_from() {
  local file="$1"
  local link="$2"
  local title

  if [ ! -f "$file" ]; then
    return
  fi

  title="$(title_for "$file")"
  printf -- '- [%s](%s)\n' "$title" "$link" >> "$BOOK_SRC/SUMMARY.md"
}

append_lang_section() {
  local lang="$1"
  local dir

  for dir in translations myths stories; do
    find "$dir" -maxdepth 1 -type f -name "*.$lang.md" | sort | while IFS= read -r file; do
      append_entry "$file"
    done
  done
}

for dir in myths stories translations; do
  copy_markdown_tree "$dir"
done

cp "$BOOK_PREFACE" "$BOOK_SRC/README.md"

cat > "$BOOK_SRC/SUMMARY.md" <<'EOF'
# Summary

[はじめに](README.md)

# 日本語版
EOF

append_lang_section "ja"

cat >> "$BOOK_SRC/SUMMARY.md" <<'EOF'

# English Edition
EOF

append_lang_section "en"

printf 'Generated %s\n' "$BOOK_SRC"
